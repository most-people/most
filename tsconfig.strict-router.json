{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "noEmit": true,
    "strictNullChecks": true,
    "paths": {
      "~/*": ["./src/*"],
      "~server/*": ["./server/*"],
      "~/features/portal/HomePage": [
        "./src/typecheck-stubs/route-component.tsx"
      ],
      "~/features/admin/AdminPage": [
        "./src/typecheck-stubs/route-component.tsx"
      ],
      "~/features/files/AppPage": [
        "./src/typecheck-stubs/route-component.tsx"
      ],
      "~/features/chat/ChatPage": [
        "./src/typecheck-stubs/route-component.tsx"
      ],
      "~/features/chat/ChatJoinPage": [
        "./src/typecheck-stubs/route-component.tsx"
      ],
      "~/features/demo/DemoPage": [
        "./src/typecheck-stubs/route-component.tsx"
      ],
      "~/features/download/DownloadPage": [
        "./src/typecheck-stubs/route-component.tsx"
      ],
      "~/features/game/gandengyan/GanDengYanPage": [
        "./src/typecheck-stubs/route-component.tsx"
      ],
      "~/features/game/zhajinhua/ZhajinhuaPage": [
        "./src/typecheck-stubs/route-component.tsx"
      ],
      "~/features/note/NotePage": [
        "./src/typecheck-stubs/route-component.tsx"
      ],
      "~/features/ping/PingPage": [
        "./src/typecheck-stubs/route-component.tsx"
      ],
      "~/features/web3/Web3Page": [
        "./src/typecheck-stubs/route-component.tsx"
      ],
      "~/features/system/ErrorBoundary": [
        "./src/typecheck-stubs/error-boundary.tsx"
      ],
      "~/features/system/NotFoundPage": [
        "./src/typecheck-stubs/route-component.tsx"
      ],
      "~/components/AppGlobals": ["./src/typecheck-stubs/route-component.tsx"]
    }
  },
  "include": [
    "src/router.tsx",
    "src/routeTree.gen.ts",
    "src/routes/**/*.tsx",
    "src/typecheck-stubs/**/*.tsx",
    "src/typecheck-stubs/**/*.d.ts"
  ]
}
