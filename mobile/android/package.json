{
  "name": "@mostbox/android",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "npm run bundle:core && expo start --dev-client",
    "android": "npm run bundle:core && expo run:android",
    "prebuild": "npm run bundle:core && expo prebuild --platform android",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/mobileCore/*.test.ts",
    "bundle:core": "bare-pack --preset android --linked --imports bare-pack-imports.cjs backend/backend.mjs --out app.bundle.js"
  },
  "dependencies": {
    "@react-native-clipboard/clipboard": "1.16.3",
    "b4a": "1.8.1",
    "bare-fs": "4.7.2",
    "bare-rpc": "1.3.3",
    "corestore": "7.10.1",
    "expo": "56.0.12",
    "expo-clipboard": "56.0.4",
    "expo-build-properties": "56.0.19",
    "expo-dev-client": "56.0.20",
    "expo-document-picker": "56.0.4",
    "expo-file-system": "56.0.8",
    "expo-linking": "56.0.14",
    "expo-sharing": "56.0.18",
    "hyperdrive": "13.3.2",
    "hyperswarm": "4.17.0",
    "ipfs-unixfs-importer": "17.0.1",
    "lucide-react-native": "1.21.0",
    "multiformats": "14.0.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-bare-kit": "0.14.5",
    "react-native-svg": "15.15.4"
  },
  "devDependencies": {
    "@types/b4a": "1.6.5",
    "@types/react": "19.2.17",
    "bare-pack": "2.1.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
