{
  "name": "@mostbox/android",
  "version": "0.4.2",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "npm run bundle:android && node scripts/start-dev-client.mjs",
    "start:ios": "npm run bundle:ios && expo start --dev-client --host lan",
    "build": "node scripts/build-apk.mjs",
    "bundle:android": "node scripts/bundle-bare.mjs --platform android",
    "bundle:ios": "node scripts/bundle-bare.mjs --platform ios",
    "eas-build-post-install": "node scripts/bundle-bare.mjs",
    "sync:native": "node scripts/sync-native-android.mjs",
    "test": "node --import tsx --test src/mobileCore/cid.test.ts src/mobileCore/protocol.test.ts src/features/chat/chatState.test.ts && node --test backend/protocol.test.mjs backend/holding-records.test.mjs backend/mobile-core.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-clipboard/clipboard": "1.16.3",
    "b4a": "1.8.1",
    "bare-fs": "4.7.2",
    "bare-rpc": "1.3.3",
    "corestore": "7.11.0",
    "expo": "~57.0.7",
    "expo-build-properties": "~57.0.6",
    "expo-clipboard": "~57.0.1",
    "expo-dev-client": "~57.0.7",
    "expo-document-picker": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-sharing": "~57.0.6",
    "hyperdrive": "13.3.2",
    "hyperswarm": "4.17.0",
    "ipfs-unixfs-importer": "17.0.1",
    "lucide-react-native": "1.21.0",
    "multiformats": "14.0.2",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-bare-kit": "0.15.0",
    "react-native-svg": "15.15.4"
  },
  "devDependencies": {
    "@types/b4a": "1.6.5",
    "@types/react": "19.2.17",
    "bare-pack": "^2.2.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
