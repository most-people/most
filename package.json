{
  "name": "most-box",
  "version": "1.0.0",
  "description": "P2P File Box powered by Pear",
  "type": "module",
  "main": "index.js",
  "imports": {
    "crypto": {
      "bare": "bare-crypto",
      "default": "crypto"
    },
    "node:crypto": {
      "bare": "bare-crypto",
      "default": "crypto"
    }
  },
  "scripts": {
    "start": "chcp 65001 && pear run --dev .",
    "postinstall": "patch-package"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "b4a": "^1.8.0",
    "bare-crypto": "^1.13.4",
    "base32-decode": "^1.0.0",
    "base32-encode": "^2.0.0",
    "blockstore-core": "^6.1.2",
    "corestore": "^7.9.1",
    "crypto": "file:shims/crypto",
    "goodbye": "^0.0.1",
    "graceful-goodbye": "^1.3.3",
    "hypercore": "^11.27.14",
    "hyperdrive": "^13.3.0",
    "hyperswarm": "^4.17.0",
    "ipfs-unixfs-importer": "^16.1.4",
    "multiformats": "^13.4.2",
    "pear-bridge": "^1.2.5",
    "pear-electron": "^1.7.28",
    "pear-message": "^1.0.0",
    "pear-messages": "^1.0.5",
    "text-encoding": "^0.7.0"
  },
  "devDependencies": {
    "patch-package": "^8.0.1",
    "pear": "latest"
  },
  "pear": {
    "name": "most-box",
    "pre": "pear-electron/pre",
    "routes": ".",
    "gui": {
      "width": 800,
      "height": 600
    },
    "webPreferences": {
      "nodeIntegration": true
    }
  }
}
