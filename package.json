{
  "name": "most-box",
  "version": "0.0.5",
  "description": "MostBox - P2P file sharing application",
  "type": "module",
  "main": "server/index.js",
  "bin": {
    "most-box": "./server/cli.js"
  },
  "files": [
    "out",
    "public",
    "server/src",
    "server/index.js",
    "server/cli.js"
  ],
  "scripts": {
    "start": "npm run build && node server/index.js",
    "build": "next build",
    "dev": "next dev",
    "test": "node --test server/tests/**/*.test.js",
    "test:unit": "node --test server/tests/unit/*.test.js",
    "format": "npx prettier --write .",
    "lint": "npx eslint ."
  },
  "keywords": [
    "p2p",
    "file-sharing",
    "hyperswarm",
    "hyperdrive"
  ],
  "license": "MIT",
  "dependencies": {
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@hono/node-server": "^2.0.0",
    "@mantine/hooks": "^9.1.0",
    "b4a": "^1.8.0",
    "busboy": "^1.6.0",
    "corestore": "^7.9.2",
    "dayjs": "^1.11.20",
    "ethers": "^6.16.0",
    "eventemitter3": "^5.0.4",
    "hono": "^4.12.14",
    "hypercore": "^11.28.1",
    "hyperdrive": "^13.3.2",
    "hyperswarm": "^4.17.0",
    "ipfs-unixfs-importer": "^16.1.5",
    "ky": "^2.0.2",
    "lucide-react": "^1.9.0",
    "multiformats": "^13.4.2",
    "next": "^16.2.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tweetnacl": "^1.0.3",
    "ws": "^8.20.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "19.2.14",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "6.0.3"
  }
}
