{
  "name": "most-box-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "MostBox - Cross-platform P2P file sharing application",
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/desktop"
  ],
  "scripts": {
    "core": "npm run start --workspace=packages/core",
    "desktop": "npm run start --workspace=packages/desktop",
    "build:desktop": "npm run make --workspace=packages/desktop",
    "test": "npm run test --workspaces --if-present"
  },
  "keywords": [
    "p2p",
    "file-sharing",
    "hyperswarm",
    "hyperdrive"
  ],
  "license": "MIT"
}
