{
  "name": "most-box-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Most Box - Cross-platform P2P file sharing application",
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/desktop",
    "packages/mobile"
  ],
  "scripts": {
    "core": "npm run start --workspace=packages/core",
    "desktop": "npm run start --workspace=packages/desktop",
    "mobile": "npm run start --workspace=packages/mobile",
    "build:desktop": "npm run make --workspace=packages/desktop",
    "test": "npm run test --workspaces --if-present"
  },
  "keywords": [
    "p2p",
    "file-sharing",
    "hyperswarm",
    "hyperdrive"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron": "^41.0.3"
  }
}
