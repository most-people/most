{
  "name": "most-desktop",
  "version": "1.0.0",
  "description": "MostBox Desktop - P2P File Sharing Application",
  "main": "electron.mjs",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --mac",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "release": "npm run build && electron-builder --win --mac --publish github"
  },
  "keywords": [
    "p2p",
    "file-sharing",
    "electron"
  ],
  "author": "MostBox Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.0"
  }
}
