{
  "name": "@most-box/desktop",
  "version": "1.0.0",
  "description": "MostBox Desktop - P2P file sharing application",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "start": "chcp 65001 >nul && set PYTHONIOENCODING=utf-8 && set NODE_OPTIONS=--max-old-space-size=4096 && electron .",
    "build": "esbuild main.js --bundle --platform=node --outfile=dist/main.js --external:electron --format=esm",
    "package": "npm run build && electron-forge package",
    "package:dev": "electron-forge package",
    "zip": "cd out && powershell -Command \"Compress-Archive -Path 'MostBox-win32-x64' -DestinationPath 'MostBox-1.0.0-portable.zip' -Force\""
  },
  "keywords": [
    "p2p",
    "file-sharing",
    "electron",
    "hyperswarm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "b4a": "^1.8.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron/packager": "^18.4.4",
    "asar": "^3.2.0",
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "esbuild": "^0.27.4"
  },
  "config": {
    "forge": "./forge.config.cjs"
  }
}
