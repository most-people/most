{
  "name": "most-core",
  "version": "1.0.0",
  "description": "MostBox Core - P2P file sharing daemon",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "npm run build && node server.js",
    "dev": "npm run build -- --dev --watch & node --watch server.js",
    "build": "node build.mjs",
    "build:prod": "node build.mjs",
    "package": "npm run build && pkg server.js --targets node16-win-x64 --output ../dist/MostBox.exe"
  },
  "keywords": [
    "p2p",
    "file-sharing",
    "hyperswarm",
    "hyperdrive"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "b4a": "^1.8.0",
    "corestore": "^7.9.2",
    "eventemitter3": "^5.0.4",
    "hyperdrive": "^13.3.1",
    "hyperswarm": "^4.17.0",
    "ipfs-unixfs-importer": "^16.1.4",
    "lucide-react": "^1.7.0",
    "multiformats": "^13.4.2",
    "pkg": "^5.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "esbuild": "^0.27.4"
  }
}
